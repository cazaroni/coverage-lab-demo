# Environment shape for platform-owned compose/runtime settings.
# Copy to `.env` in repo root (or export in CI/staging) and fill values.

DEPLOYMENT_ENV=dev
LOG_FORMAT=json

# Image references (digest pinning in later phases)
API_IMAGE=ghcr.io/projectedge/api:dev
WEB_IMAGE=ghcr.io/projectedge/web:dev
INFERENCE_IMAGE=ghcr.io/projectedge/inference:dev
REALTIME_IMAGE=ghcr.io/projectedge/realtime:dev
CHATBOT_IMAGE=ghcr.io/projectedge/chatbot:dev
ORCHESTRATOR_IMAGE=ghcr.io/projectedge/orchestrator:dev

# Core data plane
POSTGRES_DB=edge
POSTGRES_USER=edge
POSTGRES_PASSWORD=change-me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MLFLOW_BUCKET=mlflow

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Public endpoints
API_BASE_URL=http://api:8000
PROJECTEDGE_AUTH_MODE=development
PROJECTEDGE_DEVELOPMENT_AUTO_AUTH=true

# Local dev host port defaults
WEB_PORT=3000
API_PORT=8000
GRAFANA_PORT=3001
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MLFLOW_PORT=5000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# Optional profile ports
INFERENCE_PORT=3001
REALTIME_PORT=8090
CHATBOT_PORT=8092
ORCHESTRATOR_PORT=8093

# Staging ingress
CADDY_DOMAIN=staging.projectedge.local
CADDY_EMAIL=platform@example.com
ENABLE_REALTIME_INGRESS=false
