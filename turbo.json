{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["PROJECTEDGE_API_BASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "storybook-static/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**", "playwright-report/**", "test-results/**"]
    },
    "build-storybook": {
      "outputs": ["storybook-static/**"]
    },
    "perf:lighthouse": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
